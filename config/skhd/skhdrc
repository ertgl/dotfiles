ctrl + alt + cmd - s : sketchybar_toggle

ctrl + alt - m : yabai -m space --layout float
ctrl + alt - f : yabai -m space --layout stack
ctrl + alt - s : yabai -m space --layout bsp

ctrl + alt - d : yabai -m window --toggle zoom-parent
ctrl + alt - f : yabai -m window --toggle zoom-fullscreen

ctrl + shift - up : yabai -m window --focus stack.prev
ctrl + shift - down : yabai -m window --focus stack.next

ctrl + alt - up : yabai -m window --focus stack.prev || yabai -m window --focus north
ctrl + alt - right : yabai -m window --focus east
ctrl + alt - down : yabai -m window --focus stack.next || yabai -m window --focus south
ctrl + alt - left : yabai -m window --focus west

cmd + alt - t : open -a Alacritty
