<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>KeepAlive</key>
		<true />
		<key>Label</key>
		<string>ke.bou.dark-mode-notify.nvim</string>
		<key>RunAtLoad</key>
		<true />
		<key>StandardErrorPath</key>
		<string>/usr/local/var/log/dark-mode-notify/dark-mode-notify.nvim.err.log</string>
		<key>StandardOutPath</key>
		<string>/usr/local/var/log/dark-mode-notify/dark-mode-notify.nvim.out.log</string>
		<key>ProgramArguments</key>
		<array>
			<string>/usr/local/bin/dark-mode-notify</string>
			<string>/opt/homebrew/bin/fish</string>
			<string>-l</string>
			<string>-c</string>
			<string>nvim_reload_theme</string>
		</array>
	</dict>
</plist>