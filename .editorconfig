[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = tab
insert_final_newline = true
root = true
tab_width = 4
trim_trailing_whitespace = true

[*.conf]
indent_size = 4
indent_style = space

[*.el]
indent_size = 2
indent_style = space

[*.fish]
indent_size = 4
indent_style = space

[*.gitconfig]
indent_size = 4
indent_style = space

[*.json]
indent_size = 2
indent_style = space

[*.lua]
indent_size = 2
indent_style = space

[*.md]
indent_size = 2
indent_style = space

[*.sh]
indent_size = 2
indent_style = space

[*.tmux]
indent_size = 2
indent_style = space

[*.toml]
indent_size = 4
indent_style = space

[Brewfile]
indent_size = 2
indent_style = space

